# -----------------------------------------------------------------------------
# archetype-core-etl — local development environment variables
#
# Copy this file to `.env` and replace every CHANGE_ME placeholder with a real
# value. Never commit the resulting `.env` file — it is already gitignored.
#
#   cp .env.example .env
#
# Helpful generators:
#   Fernet key:     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   Secret key:     python -c "import secrets; print(secrets.token_urlsafe(48))"
#   Strong passwd:  python -c "import secrets; print(secrets.token_urlsafe(24))"
# -----------------------------------------------------------------------------

# ---------- PostgreSQL ----------
POSTGRES_USER=archetype
POSTGRES_PASSWORD=CHANGE_ME
AIRFLOW_DB_NAME=airflow
AUDIT_DB_NAME=archetype_audit

# ---------- Redis (Celery broker) ----------
REDIS_PASSWORD=CHANGE_ME

# ---------- Airflow core ----------
# Must be a 32-byte url-safe base64 key. Generate with the Fernet snippet above.
AIRFLOW_FERNET_KEY=CHANGE_ME
AIRFLOW_WEBSERVER_SECRET_KEY=CHANGE_ME
AIRFLOW_WEBSERVER_PORT=8080

# ---------- Airflow admin user (created on first run) ----------
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_ADMIN_EMAIL=admin@localhost
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User

# ---------- AWS / LocalStack ----------
# LocalStack accepts any non-empty credentials; real values are only needed
# when pointing at a real AWS account (see docker-compose.override.yml.example).
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ---------- Application settings ----------
# Consumed by src/archetype_core_etl/config/settings.py (pydantic-settings).
# All ARCHETYPE_* variables are required unless marked optional in settings.py.
ARCHETYPE_ENVIRONMENT=dev
ARCHETYPE_DB_AUDIT_URL=CHANGE_ME
ARCHETYPE_AWS_REGION=us-east-1
ARCHETYPE_AWS_ENDPOINT_URL=http://localstack:4566
ARCHETYPE_AWS_RAW_BUCKET=archetype-raw
ARCHETYPE_AWS_PROCESSED_BUCKET=archetype-processed
ARCHETYPE_AWS_AUDIT_BUCKET=archetype-audit
ARCHETYPE_AIRFLOW_DAG_BUCKET=archetype-dags
ARCHETYPE_AIRFLOW_ENVIRONMENT_NAME=local-dev
ARCHETYPE_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
ARCHETYPE_BEDROCK_REGION=us-east-1
ARCHETYPE_AWS_KINESIS_STREAM_NAME=archetype-documents
ARCHETYPE_DATABRICKS_HOST=https://localhost
ARCHETYPE_DATABRICKS_WAREHOUSE_ID=local-warehouse
ARCHETYPE_DATABRICKS_CATALOG=local_catalog
ARCHETYPE_DATABRICKS_SCHEMA_NAME=default
